# Environment Variables for GIS Agent

# ====================
# Python Environment - ArcGIS Pro
# ====================
# If ArcGIS Pro is installed, use its Python environment
ARCGIS_PRO_PYTHON=C:\Program Files\ArcGIS\Pro\bin\Python\envs\arcgispro-py3\python.exe

# Otherwise use the system Python (already configured)
# ARCGIS_PRO_PYTHON=python

# ====================
# 模型提供商配置 / Model Provider Configuration
# ====================
DEFAULT_PROVIDER=dashscope
DASHSCOPE_API_KEY=sk-sp-6e2306351d874137b30d9918cdadf684
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# ====================
# 应用设置 / Application Settings
# ====================
ENVIRONMENT=development
DEBUG=true

# ====================
# 工作空间和数据设置 / Workspace and Data Settings
# ====================
WORKSPACE_DIR=./workspace
DATA_DIR=./data

# ====================
# Agent 设置 / Agent Settings
# ====================
MAX_ITERATIONS=200
MEMORY_WINDOW=50

# ====================
# 网络搜索 API 配置 / Web Search API Configuration
# ====================
# Tavily Search API (推荐使用 / Recommended)
TAVILY_API_KEY=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
# Brave Search API (备用 / Alternative)
BRAVE_API_KEY=

# ====================
# 服务器设置 / Server Settings
# ====================
HOST=0.0.0.0
PORT=8000
