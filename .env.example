# Environment Variables Template for GIS Agent

# ====================
# Python Environment - ArcGIS Pro
# ====================
# If ArcGIS Pro is installed, use its Python environment
# ARCGIS_PRO_PYTHON=C:\Program Files\ArcGIS\Pro\bin\Python\envs\arcgispro-py3\python.exe

# Use .venv Python environment
# ARCGIS_PRO_PYTHON=.venv\Scripts\python.exe

# ====================
# 模型提供商配置 / Model Provider Configuration
# ====================
# 至少配置一个API密钥 / Configure at least one API key

DEFAULT_PROVIDER=dashscope

# Dashscope (阿里云) - https://dashscope.aliyuncs.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Anthropic (Claude) - https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (GPT) - https://platform.openai.com/
# OPENAI_API_KEY=your-openai-api-key-here

# ====================
# 应用设置 / Application Settings
# ====================
ENVIRONMENT=development
DEBUG=false

# ====================
# 工作空间和数据设置 / Workspace and Data Settings
# ====================
WORKSPACE_DIR=./workspace
DATA_DIR=./workspace/data

# ====================
# Agent 设置 / Agent Settings
# ====================
MAX_ITERATIONS=15
MEMORY_WINDOW=50

# ====================
# 网络搜索 API 配置 / Web Search API Configuration
# ====================
# Tavily Search API (推荐使用 / Recommended)
# TAVILY_API_KEY=your-tavily-api-key-here

# ====================
# 服务器设置 / Server Settings
# ====================
HOST=0.0.0.0
PORT=8080
