# Environment Variables for GIS Agent

# ====================
# Python Environment
# ====================
# ArcGIS Pro Python 环境路径（包含 ArcPy）
ARCGIS_PRO_PYTHON=C:\Program Files\ArcGIS\Pro\bin\Python\envs\arcgispro-py3\python.exe

# ====================
# 模型提供商配置 / Model Provider Configuration
# ====================

# 默认模型提供商 / Default Model Provider (dashscope, anthropic, openai)
DEFAULT_PROVIDER=dashscope

# 阿里云百炼 Coding Plan API 配置 / Dashscope Coding Plan Configuration
DASHSCOPE_API_KEY=sk-sp-6e2306351d874137b30d9918cdadf684
DASHSCOPE_MODEL=qwen3.5-plus
# Coding Plan 专属 Base URL（兼容 OpenAI 协议）
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI API Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ====================
# Web Search Configuration / Web Search Configuration
# ====================
# Brave Search API Key (for web_search tool)
BRAVE_API_KEY=your_brave_api_key_here

# ====================
# Coding Plan 支持的模型 / Supported Models
# ====================
# 可用模型 / Available Models:
# - qwen3.5-plus (文本生成、深度思考、视觉理解)
# - qwen3-max-2026-01-23 (文本生成、深度思考)
# - qwen3-coder-next (文本生成)
# - qwen3-coder-plus (文本生成)
# - glm-5 (智谱，文本生成、深度思考)
# - glm-4.7 (智谱，文本生成、深度思考)
# - kimi-k2.5 (文本生成、深度思考、视觉理解)
# - MiniMax-M2.5 (文本生成、深度思考)

# ====================
# 应用设置 / Application Settings
# ====================
ENVIRONMENT=development
DEBUG=true

# ====================
# 工作空间和数据设置 / Workspace and Data Settings
# ====================
WORKSPACE_DIR=./workspace
DATA_DIR=./data

# ====================
# Agent 设置 / Agent Settings
# ====================
MAX_ITERATIONS=15
MEMORY_WINDOW=50

# ====================
# 服务器设置 / Server Settings
# ====================
HOST=0.0.0.0
PORT=8000